# Copier en infra/.env sur le serveur (jamais commité).
# chmod 600 infra/.env
# Les valeurs réelles sont générées sur le serveur au moment du déploiement
# (voir infra/deploy.sh) — ne jamais mettre de vrai secret ici ni ailleurs dans le repo.

# PostgreSQL (service db interne - pas exposé sur le réseau public)
POSTGRES_USER=kombien
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=kombien

# API - secret admin (header x-admin-secret). Générer avec : openssl rand -hex 32
ADMIN_SECRET=CHANGE_ME_32_HEX_CHARS

# Redis (multi-écrans temps réel, Lot 9) - réseau interne uniquement, pas de
# port exposé, pas de mot de passe (isolé du réseau public). REDIS_URL est déjà
# fixée en dur dans docker-compose.yml (redis://kombien-redis:6379) : rien à
# ajouter ici, ligne présente pour documentation.
# REDIS_URL=redis://kombien-redis:6379
