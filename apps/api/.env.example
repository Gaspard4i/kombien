# Copier en .env (jamais commité) et remplacer les CHANGE_ME.
# Aucune valeur réelle de secret ne doit apparaître ici.

DATABASE_URL=postgres://kombien:CHANGE_ME@localhost:5432/kombien
ADMIN_SECRET=CHANGE_ME
PORT=3000

# Optionnel : origine autorisée pour CORS en production (sinon permissif).
# CORS_ORIGIN=https://kombien.gazai.fr

# Rooms multi-écrans (Lot 9). REDIS_URL a un défaut dev (redis://127.0.0.1:6379).
# WEB_BASE_URL sert à construire le lien encodé dans le QR de room.
# REDIS_URL=redis://127.0.0.1:6379
# WEB_BASE_URL=https://kombien.gazai.fr
