{
  "name": "kombien-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=html --include='src/domain/**' --check-coverage --lines 100 --functions 100 --branches 100 --statements 100 node --experimental-strip-types --test test/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/postgres": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "csv-parse": "^7.0.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.9.0",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "redis": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "c8": "^10.1.0",
    "typescript": "^5.7.0"
  }
}
