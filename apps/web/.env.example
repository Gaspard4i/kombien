# Copier en .env.local (jamais commité) si besoin de surcharger.
# Par défaut : /api (proxy nginx en prod) ou http://localhost:3000 en dev (npm run dev).

VITE_API_BASE=/api

# WebSocket multi-écrans (Lot 9) - direct vers l'api (nginx ne relaie pas les
# headers Upgrade), PAS via le proxy /api. Dev : ws://localhost:3000. Prod :
# wss://kombien-api.gazai.fr (Traefik v3 gère l'upgrade WS nativement).
VITE_WS_BASE=ws://localhost:3000
